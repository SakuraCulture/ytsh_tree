# 开发环境配置
NODE_ENV=development

VITE_DEV=true

# 请求路径 - 开发环境后端地址（端口8080）
# 开发环境留空，让 axios 使用相对路径 /admin-api，请求经 Vite 代理转发到后端
VITE_BASE_URL=''
# Vite 代理目标地址（仅 vite.config.ts proxy 使用）
VITE_PROXY_TARGET_URL='http://localhost:8080'
# 后端服务地址（用于 iframe 嵌入的 Swagger/Druid 等页面直接访问后端）
VITE_BACKEND_URL='http://localhost:8080'

# 文件上传类型：server - 后端上传，client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=server

# 接口地址
VITE_API_URL=/admin-api

# 是否删除debugger
VITE_DROP_DEBUGGER=false

# 是否删除console.log
VITE_DROP_CONSOLE=false

# 是否sourcemap
VITE_SOURCEMAP=true

# 打包路径
VITE_BASE_PATH=/

# 商城H5会员端域名
VITE_MALL_H5_DOMAIN='http://localhost:3000'

# 验证码的开关
VITE_APP_CAPTCHA_ENABLE=false

# GoView域名
VITE_GOVIEW_URL='http://127.0.0.1:3000'
